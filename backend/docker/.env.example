# docker部署配置模板
# 复制此文件为 .env 并填入实际配置


# 项目名称: Teo Estuary 后端服务
COMPOSE_PROJECT_NAME=teo-estuary

# Flask 应用配置
SECRET_KEY=your-secret-key-change-in-production
DEBUG=False
HOST=0.0.0.0
PORT=5000

# Dify Webhook 配置（用于生成参考文本）
# Dify webhook触发URL
DIFY_WEBHOOK_URL=your-Dify-workflow-webhook-trigger-URL

# Webhook 密钥（后端回调时用于鉴权）
WEBHOOK_KEY=your-webhook-secret-key-change-in-production

# 管理员账户配置（应用启动时自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password

# Redis配置 - 用于速率限制和翻译缓存
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# 缓存配置 - 翻译结果缓存
USE_FILE_CACHE=false
CACHE_DIR=./cache/teo_g2p

#速率限制器开关配置
# 设置为 True 启用所有限制（线上版本），设置为 False 禁用所有限制（离线无限制版）
# 离线版默认禁用，如需启用限流，修改为 True
ENABLE_RATE_LIMITER=False

# Flask-Limiter 速率限制配置 (Docker环境)
RATELIMIT_STORAGE_URL=redis://redis:6379          # 使用Redis存储 (生产环境推荐)
RATELIMIT_DEFAULT=1000 per day, 100 per hour     # 默认全局速率限制

# Emilia服务配置（可选）
# 如果使用Emilia服务进行音频处理，设置其URL
# Docker访问宿主机: http://host.docker.internal:5029 (Windows/Mac)
# Docker访问宿主机: http://172.17.0.1:5029 (Linux)
# Docker内访问: http://emilia:5029 (如果emilia在同一docker网络)
# 本地测试: http://localhost:5029
EMILIA_SERVICE_URL=http://host.docker.internal:5029

# ASR语音识别服务配置（可选）
# 如果使用ASR服务进行潮汕话语音识别，设置其URL
# Docker访问宿主机: http://host.docker.internal:5026 (Windows/Mac)
# Docker访问宿主机: http://172.17.0.1:5026 (Linux)
# Docker内访问: http://teo-asr:5026 (如果teo-asr在同一docker网络)
# 本地测试: http://localhost:5026
ASR_SERVICE_URL=http://host.docker.internal:5026

# Gunicorn 配置
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# MySQL 数据库配置
# MySQL 服务地址（Docker 网络内使用服务名，本地开发使用 localhost）
# 注意：Docker容器间通信使用内部端口3306，宿主机访问使用映射端口33060
MYSQL_HOST=mysql
MYSQL_PORT=3306
# MySQL 用户配置（生产环境建议修改密码）
MYSQL_USER=root
MYSQL_PASSWORD=teo_root_password
# MySQL root 密码（用于初始化 MySQL 容器）
MYSQL_ROOT_PASSWORD=teo_root_password
# 数据库名称
MYSQL_DATABASE=teo_estuary

# 生产环境建议：
# - 使用更强的SECRET_KEY
# - 设置复杂的ADMIN_PASSWORD
# - 监控Redis连接状态
# - 如需使用Emilia音频处理服务，需要另外部署Teo-Emilia服务并正确配置EMILIA_SERVICE_URL