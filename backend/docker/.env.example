# Flask配置
SECRET_KEY=your-secret-key-change-in-production
DEBUG=False
HOST=0.0.0.0
PORT=5000

# 数据库配置
DATABASE_URL=sqlite:///instance/dialect_recorder.db

# 硅基流动API配置
SILICONFLOW_API_KEY=your-api-key-here

# 管理员配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password

# Flask-Limiter 速率限制配置 (Docker环境)
RATELIMIT_STORAGE_URL=redis://redis:6379          # 使用Redis存储 (生产环境推荐)
RATELIMIT_DEFAULT=1000 per day, 100 per hour     # 默认全局速率限制

# Emilia服务配置（可选）
# 如果使用Emilia服务进行音频处理，设置其URL
# Docker内访问: http://emilia:5029 (如果emilia在同一网络)
# Docker访问宿主机: http://host.docker.internal:5029 (Linux不支持)
# 本地测试: http://localhost:5029
EMILIA_SERVICE_URL=http://localhost:5029

# 生产环境建议：
# - 使用更强的SECRET_KEY
# - 设置复杂的ADMIN_PASSWORD
# - 确保SILICONFLOW_API_KEY有效
# - 监控Redis连接状态
# - 如需使用Emilia服务，正确配置EMILIA_SERVICE_URL