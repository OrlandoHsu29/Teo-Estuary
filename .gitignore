# Pixi environments (不包含版本控制的依赖环境)
frontend/.pixi/
backend/.pixi/

# IDE和编辑器配置
.claude/
.idea/
.vscode/
*.swp
*.swo

# 环境配置文件 (包含敏感信息)
.env
.env.local
.env.development
.env.test
.env.production
backend/docker/.env

# 运行时生成的文件 (自动生成，不需要版本控制)
logs/
*.log
instance/
*.db
*.sqlite
*.sqlite3

# 用户上传的文件 (包含用户数据，应该保密)
backend/data/
*.webm
*.mp3
*.wav

# Python缓存 (自动生成)
__pycache__/
*.pyc
*.pyo
*.pyd

# 临时文件
*.tmp
*.temp
*.bak
.cache/
.DS_Store

# 操作系统文件
Thumbs.db
backend/data/bad/S001/F001/S001F001C001.webm
