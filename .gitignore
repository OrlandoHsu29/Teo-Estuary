# Pixi environments (不包含版本控制的依赖环境)
frontend/.pixi/
backend/.pixi/

# IDE和编辑器配置
.claude/
.idea/
.vscode/

# 环境配置文件 (包含敏感信息)
.env
backend/docker/.env

# 运行时生成的文件 (自动生成，不需要版本控制)
logs/
*.log

# instance 目录配置
instance/
!backend/docker/instance/

*.db
!backend/instance/translation_dict.db
!backend/docker/instance/translation_dict.db
*.sqlite
*.sqlite3

# 用户上传的文件 (包含用户数据，应该保密)
backend/data/
*.webm
*.mp3
*.wav

# 词典文件 (自动生成或用户特定)
backend/app/teo_g2p/word_dict/jieba_cut.txt

# Python缓存 (自动生成)
__pycache__/
*.pyc
*.pyo
*.pyd

# 临时文件
*.tmp
*.temp
*.bak
.cache/
.DS_Store